  "yourHealthInYourHandsPage": {
    "title": "Votre santé entre vos mains",
    "subtitle": "Vous donner les moyens de prendre le contrôle de votre santé",
    "description": "Des outils et des informations pour vous aider à prendre des décisions éclairées en matière de santé.",
    "mainHeading": "Prenez le contrôle : votre santé, vos décisions, votre parcours",
    "sections": {
      "uniqueProfile": {
        "title": "Comprendre votre profil unique",
        "description1": "Obtenez une vision plus précise de votre bien-être personnel. Notre plateforme vous aide à relier les points clés et à comprendre les facteurs qui contribuent à votre vitalité globale.",
        "description2": "Explorez différentes facettes de votre bien-être, des habitudes de vie aux préférences personnelles, le tout en un seul endroit."
      },
      "personalizedGoals": {
        "title": "Définissez et suivez vos objectifs personnalisés",
        "description1": "Définissez ce que le bien-être signifie pour vous. Avec VirtualMD.app, fixez-vous des objectifs significatifs et atteignables et suivez vos progrès. Nous vous fournissons les outils et le soutien nécessaires pour rester motivé et célébrer vos réussites.",
        "description2": "Qu'il s'agisse d'améliorer les niveaux d'énergie, d'améliorer le sommeil ou de favoriser la clarté mentale, votre parcours est unique."
      },
      "diverseInsights": {
        "title": "Accédez à des informations diverses pour des choix éclairés",
        "description1": "Savoir, c'est pouvoir. Notre plateforme vous donne accès à un large éventail d'informations et de perspectives issues de nos divers guides bien-être basés sur l'IA. Prenez des décisions éclairées, fondées sur une compréhension globale, et non sur des faits isolés.",
        "description2": "Nous vous aidons à naviguer dans le monde complexe des informations sur le bien-être, afin que vous puissiez choisir ce qui vous convient."
      },
      "proactivePartner": {
        "title": "Votre partenaire en bien-être proactif",
        "description1": "VirtualMD.app est plus qu'un simple outil ; nous sommes votre partenaire pour bâtir une relation proactive et positive avec votre santé. Nous sommes là pour vous accompagner avec des ressources, des conseils et une approche révolutionnaire du bien-être personnel.",
        "description2": "Soyez la révolution dans votre vie. Commencez dès aujourd'hui votre parcours bien-être."
      }
    },
    "callToAction": {
      "title": "Prêt à mettre votre santé entre vos mains ?",
      "description": "Explorez nos fonctionnalités, discutez avec nos guides de bien-être IA et découvrez la différence que VirtualMD.app peut faire."
    }
  },
  "aboutEncyclopediaPage": {
    "title": "Encyclopédie VirtualMD de la santé et du bien-être",
    "mainHeading": " ",
    "p1": "Dans le monde numérique d’aujourd’hui, un flot d’informations sur la santé est à portée de main, mais distinguer les conseils crédibles de la désinformation peut être difficile.",
    "p2": "L'encyclopédie VirtualMD.app vous offre une approche révolutionnaire pour prendre soin de votre bien-être. Intégrée de manière unique à notre plateforme, elle vous permet d'accéder à des informations approfondies et référencées provenant de revues médicales réputées sans quitter votre consultation en direct avec notre équipe d'experts en IA.",
    "p3": "Il ne s’agit pas simplement d’un moteur de recherche ; c’est un composant de « recherche approfondie » spécialement formé, conçu pour être votre ressource de confiance lors d’une conversation.",
    "p4": "Imaginez que vous discutez de gestion du cholestérol avec notre cardiologue et nutritionniste assistés par IA. Le terme « statines » est mentionné et vous souhaitez en savoir plus. Au lieu d'interrompre votre discussion pour effectuer des recherches sur Internet, accédez instantanément à l'encyclopédie VirtualMD.app. Elle vous fournira un résumé complet et facile à comprendre du fonctionnement des statines, de leurs bienfaits et de leurs effets secondaires potentiels, avec toutes les informations issues de publications à comité de lecture comme The Lancet ou le New England Journal of Medicine."
  },
  "dataPrivacyPage": {
    "title": "Confidentialité et sécurité des données",
    "subtitle": "Vos données de santé sont protégées par les normes de sécurité les plus élevées",
    "description": "Découvrez comment nous protégeons vos renseignements personnels sur la santé."
  },
  "encyclopediaPage": {
    "title": "Encyclopédie de la santé VirtualMD",
    "subtitle": "Des connaissances médicales complètes à portée de main",
