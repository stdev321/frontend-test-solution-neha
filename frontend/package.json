    "@mui/material": "^5.13.0",
    "@mui/x-data-grid": "^8.5.1",
    "axios": "^1.6.0",
    "detect-url-change": "^1.0.2",
    "firebase": "^9.23.0",
    "framer-motion": "^12.23.6",
    "html2canvas": "^1.4.1",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
