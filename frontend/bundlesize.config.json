{
  "files": [
    {
      "path": "./dist/assets/*.js",
      "maxSize": "500 kB",
      "compression": "gzip"
    },
    {
      "path": "./dist/assets/*.css",
      "maxSize": "100 kB",
      "compression": "gzip"
    },
    {
      "path": "./dist/**/*",
